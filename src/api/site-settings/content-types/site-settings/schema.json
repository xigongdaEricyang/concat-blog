{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-settings",
    "pluralName": "site-settings-items",
    "displayName": "站点设置",
    "description": "站点级 SEO、sitemap 与 robots 配置"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "siteUrl": {
      "type": "string",
      "required": true
    },
    "defaultChangefreq": {
      "type": "enumeration",
      "enum": ["daily", "weekly", "monthly"],
      "default": "weekly"
    },
    "defaultPriority": {
      "type": "decimal",
      "default": 0.7
    },
    "sitemapEnabled": {
      "type": "boolean",
      "default": true
    },
    "robotsEnabled": {
      "type": "boolean",
      "default": true
    },
    "robotsDisallowPaths": {
      "type": "json"
    },
    "robotsCustomLines": {
      "type": "text"
    },
    "seoDefault": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo-meta"
    }
  }
}
