{
  "kind": "collectionType",
  "collectionName": "copy_entries",
  "info": {
    "singularName": "copy-entry",
    "pluralName": "copy-entries",
    "displayName": "文案项",
    "description": "按 key_path 映射的多语言文案项"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "keyPath": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "valueType": {
      "type": "enumeration",
      "enum": ["text", "json"],
      "required": true
    },
    "valueText": {
      "type": "text"
    },
    "valueJson": {
      "type": "json"
    },
    "group": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "order": {
      "type": "integer"
    }
  }
}
